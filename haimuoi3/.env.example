# Copy to .env for local docker-compose / IDE (never commit .env)

SPRING_PROFILES_ACTIVE=dev

# Server (Railway sets PORT automatically)
PORT=8090

# JWT (required)
JWT_SECRET=change-me-min-32-chars-for-local-dev-only

# Stripe (required for checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (Stripe redirects)
APP_BASE_URL=http://localhost:4200

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Postgres (local docker-compose)
DATABASE_HOST=localhost
DATABASE_PORT=5431
DATABASE_NAME=haimuoi3-backend
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password

# Railway Postgres plugin: set DATABASE_URL instead (auto-parsed in prod profile)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# MongoDB (local)
MONGODB_HOST=localhost
MONGODB_PORT=27010
MONGODB_DATABASE=haimuoi3-backend

# Railway / Atlas: use connection string (prod profile)
# MONGODB_URI=mongodb://user:pass@host:27017/haimuoi3-backend
# MONGO_URL=mongodb+srv://...
